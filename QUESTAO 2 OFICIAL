    <?php
    if($_SERVER["REQUEST_METHOD"] == "POST"){
        $num = $_POST['num'] ;
        $valor = (float) $_POST["valor"];
        switch ($num){
            case 1:
               $tipo = "Refrigerante";
               $preco = 5.00;
                break;
            case 2:
                $tipo = "Sanduiche";
                $preco = 7.00;
                break;
            case 3:
                $tipo = "Fatia de Pizza";
                $preco = 6.00;
                break;
            case 4:
                $tipo = "Café";
                $preco = 3.50;
                break;
            case 5:
                $tipo = "Suco de Caixinha";
                $preco = 4.50;
                break;
            case 6:
                $tipo = "Chocolate Quente";
                $preco = 8.00;
                break;
            default:
                echo "PRODUTO INEXISTENTE OU INVÁLIDO";
                echo "VALOR DEVOLVIDO";
                exit();
        }
        if ($valor < $preco){
        echo "Valor Insuficiente <br>";
        echo "Dinheiro Devolvido";
        }
        else{
            $troco = $valor - $preco;
            echo "Produto escolhido: $tipo <br>";
            echo "Preço do serviço: $preco <br>";
            echo "Troco: $troco <br>";
        }
    }
