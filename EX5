    if($_SERVER["REQUEST_METHOD"] == "POST"){
        $num = $_POST['num'] ;
        $valor = (float) $_POST["valor"];
        switch ($num){
            case 1:
               $tipo = "MINERAL";
               $preco = 70.00;
                break;
            case 2:
                $tipo = "SEMI-SINTÉTICO";
                $preco = 100.00;
