if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $primeiroNome = $_POST['pNome'];
    $segundoNome = $_POST['sNome'];

    $primeiroNumero = $_POST['n1'];
    $segundoNumero = $_POST['n2'];
    $terceiroNumero = $_POST['n3'];
    $quartoNumero = $_POST['n4'];

    $multiplicacao = $primeiroNumero * $terceiroNumero;

    $resto = $multiplicacao % $quartoNumero;

    echo "<hr>";

    echo "Quarto Número >= Terceiro Número bool = ";
    var_dump($quartoNumero >= $terceiroNumero);

    echo "<br><br>";

    echo "Segundo Número == Primeiro Número = ";
    var_dump($segundoNumero == $primeiroNumero);

    echo "<br><br>";

    echo "A raiz quadrada do Primeiro Número ($primeiroNumero) = "
        . sqrt($primeiroNumero);

    echo "<br><br>";

    echo "O Primeiro Número ($primeiroNumero) elevado ao Terceiro Número ($terceiroNumero) = "
        . pow($primeiroNumero, $terceiroNumero);

    echo "<br><br>";

    echo "Arredondando Segundo Número ($segundoNumero) = "
        . round($segundoNumero);

    echo "<br><br>";

    echo "O Segundo Nome: $segundoNome possui "
        . mb_strlen($segundoNome) . " caracteres";

    echo "<br><br>";

    echo "O primeiro Nome: $primeiroNome com todos caracteres em Minúsculo = "
        . strtolower($primeiroNome);

    echo "<br><br>";

    echo "Primeiro Nome == Segundo Nome = ";
    var_dump($primeiroNome == $segundoNome);

    echo "<br><br>";

    echo "O Primeiro Número ($primeiroNumero) multiplicado pelo Terceiro Número ($terceiroNumero) = $multiplicacao";

    echo "<br><br>";

    echo "O resto da divisão de ($multiplicacao) pelo Quarto Número ($quartoNumero) = $resto";
