<body>
    <h3>CÁLCULO DE SALÁRIO DO FUNCIONÁRIO</h3>
    <form method="POST">
        <label>Digite o nome do funcionário:</label><br><br>
        <input type="text" name="nome" required/><br><br>

        <label>Digite a quantidade de horas trabalhadas no mês:</label><br><br>
        <input type="number" name="horas" step="1" required/><br><br>

        <input type="submit" value="Calcular"/>   
    </form>

    <?php
    if ($_SERVER["REQUEST_METHOD"] == "POST") {
        $nome = $_POST['nome'];
        $horas = (int) $_POST['horas'];

    
        if ($horas <= 160) {
            $salario = $horas * 15;
        } elseif ($horas > 160) {
            $horasExtras = $horas - 160;
            $salario = (160 * 15) + ($horasExtras * 20);
        } else {
            $salario = 0;
        }

        echo "Funcionário: $nome <br>";
        echo "Horas trabalhadas: $horas <br>";
        echo "Salário: R$ " . number_format($salario, 2, ',', '.') . "<br>";
    }
    ?>
</body>
</html>
